# API
# Local Docker / native: mongodb://localhost:27017/healthscan
# Atlas: mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/healthscan
MONGODB_URI=mongodb://localhost:27017/healthscan
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
PORT=3000
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# Mobile / Expo (also set in app.json extra.apiUrl or EXPO_PUBLIC_API_URL)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional push
FCM_ENABLED=false
